######################################
#         GitLab Runner Setup        #
######################################

# GitLab project registration URL (likely https://gitlab.com/)
CI_SERVER_URL=https://gitlab.com/

# Legacy registration token (older GitLab workflow)
REGISTRATION_TOKEN=

# Runner authentication token (newer GitLab workflow, often starts with glrt-)
RUNNER_AUTH_TOKEN=your_gitlab_runner_token_here

# Comma-separated list of tags to assign to this runner
RUNNER_TAGS=multipass,ci

# Max jobs to run in parallel (GitLab's global `concurrent` in config.toml).
# Leave BLANK to autoscale at boot: the runner picks the smaller of
#   - CPU limit:  number of vCPUs (nproc)
#   - RAM limit:  floor(80% of total RAM / RUNNER_JOB_MEM_MB)
# e.g. 4 vCPU / 4G -> 2 jobs; 4 vCPU / 8G -> 4 jobs. Set a number here to
# override the autoscaler and pin concurrency explicitly.
RUNNER_CONCURRENT=
# Estimated RAM per job (MB), used by the autoscaler's RAM limit above.
# Memory is usually the binding constraint, not CPU. Cypress + headless
# Chrome is memory-hungry, so ~1536 is a safe default; lower it for lighter
# jobs to allow more parallelism. Ignored when RUNNER_CONCURRENT is set.
RUNNER_JOB_MEM_MB=1536

######################################
#         Multipass VM Config        #
######################################

# Ubuntu version (default: 22.04)
VM_OS=22.04

# The name of the Multipass VM
VM_NAME=gitlab-runner-vm

# VM resources
VM_CPUS=4
VM_MEMORY=8G
VM_DISK=10G

# Set to true to delete and recreate the VM every time
VM_REBUILD=false
